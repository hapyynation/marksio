# ─────────────────────────────────────────────
# Marksio — Required Environment Variables
# Copy to .env.local and fill in the values
# ─────────────────────────────────────────────

# ── Database (Supabase PostgreSQL) ───────────
DATABASE_URL="postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres"

# ── Supabase Auth ────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# ── App URLs ─────────────────────────────────
NEXT_PUBLIC_APP_URL=https://app.marksio.com
# Used for email tracking links and unsubscribe URLs
NEXTAUTH_URL=https://app.marksio.com
NEXTAUTH_SECRET=<generate-with-openssl-rand-base64-32>

# ── Email (Resend) ────────────────────────────
RESEND_API_KEY=re_<your-key>
# System/transactional email address (must be verified in Resend)
# mg.marksio.com is the mail subdomain — add it as a domain in Resend first
SYSTEM_FROM_EMAIL=noreply@mg.marksio.com
SYSTEM_SENDER_NAME=Marksio

# ── AI Providers ─────────────────────────────
GROQ_API_KEY=gsk_<your-key>
ANTHROPIC_API_KEY=sk-ant-<your-key>
OPENAI_API_KEY=sk-<your-key>
GEMINI_API_KEY=<your-key>

# ── Image Generation (fal.ai) ─────────────────
FAL_KEY=<your-key>

# ── Shopify Integration ───────────────────────
SHOPIFY_CLIENT_ID=<from-partner-dashboard>
SHOPIFY_CLIENT_SECRET=<from-partner-dashboard>
SHOPIFY_WEBHOOK_SECRET=<from-shopify-admin-webhooks>

# ── WhatsApp (Meta Cloud API) ─────────────────
WHATSAPP_VERIFY_TOKEN=<choose-a-secret-string>
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=

# ── Lemon Squeezy (Billing) ──────────────────
LEMONSQUEEZY_API_KEY=<from-ls-dashboard-api-keys>
LEMONSQUEEZY_WEBHOOK_SECRET=<from-ls-dashboard-webhooks>
LEMONSQUEEZY_STORE_ID=<optional-auto-fetched-if-omitted>
LS_VARIANT_STARTER=1741638
LS_VARIANT_GROWTH=1741701
LS_VARIANT_AGENCY=1741713

# ── Cron Job Security ─────────────────────────
CRON_SECRET=<choose-a-secret-string>

# ── Upstash QStash (Automation Wait Node) ─────
# Upstash Console → QStash → API Keys
QSTASH_TOKEN=<from-upstash-console>
QSTASH_CURRENT_SIGNING_KEY=<from-upstash-console>
QSTASH_NEXT_SIGNING_KEY=<from-upstash-console>

# ── Dev/Test ──────────────────────────────────
TEST_EMAIL=yourname@example.com
