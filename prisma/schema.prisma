generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String
  name        String
  storeName   String
  plan        String   @default("starter")
  currency    String   @default("TRY")
  language    String   @default("tr")
  timezone    String   @default("Europe/Istanbul")
  onboarded     Boolean  @default(false)
  onboardingData String  @default("{}")
  emailVerified Boolean  @default(false)

  // Lemon Squeezy billing
  lsSubscriptionId  String?
  lsCustomerId      String?
  lsOrderId         String?
  planStatus        String   @default("active") // active | cancelled | expired | past_due
  planRenewsAt      DateTime?
  emailQuotaUsed    Int      @default(0)
  whatsappQuotaUsed Int      @default(0)
  quotaResetAt      DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaigns    Campaign[]
  emailVerifications EmailVerification[]
  customers    Customer[]
  automations  Automation[]
  segments     Segment[]
  templates    Template[]
  integrations Integration[]
  orders       Order[]
  emailDomains EmailDomain[]

  whatsappSettings     WhatsAppSettings?
  whatsappQuickReplies WhatsAppQuickReply[]
  whatsappConversations WhatsAppConversation[]
  whatsappCampaigns    WhatsAppCampaign[]
  whatsappAccounts     WhatsappAccount[]

  emailTemplates  EmailTemplate[]
  emailHealthScore EmailHealthScore?
  abTests         ABTest[]
}

model Campaign {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  type        String
  status      String   @default("draft")
  segment     String
  subject     String?
  previewText String?
  headline    String?
  body        String
  design      String   @default("[]")
  cta         String?
  tips        String   @default("[]")
  purpose     String?
  imageUrl    String?
  imagePrompt String?
  htmlContent String?
  ctaText     String?
  ctaUrl      String?
  layoutStyle String?
  brandColor  String?
  templateType String?
  sentAt      DateTime?

  sent        Int      @default(0)
  opened      Int      @default(0)
  clicked     Int      @default(0)
  converted   Int      @default(0)
  revenue     Float    @default(0)

  productsJson  String   @default("[]")

  scheduledAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  opens       CampaignOpen[]
  emailEvents EmailEvent[]
  revenues    CampaignRevenue[]
  recipients  CampaignRecipient[]
}

// ─── Revenue Attribution ──────────────────────────────────────────────────────

model CampaignRevenue {
  id              String   @id @default(cuid())
  userId          String
  campaignId      String
  campaign        Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  orderId         String
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customerId      String

  revenue         Float    // attributed revenue
  orderTotal      Float    // original order total (before attribution split)
  attributionType String   @default("last_click") // last_click | first_click | assisted
  daysSinceClick  Int?
  touchCount      Int      @default(1) // # of campaigns that touched this customer

  createdAt       DateTime @default(now())

  @@unique([orderId, campaignId, attributionType])
  @@index([campaignId, createdAt])
  @@index([userId, createdAt])
  @@index([customerId])
}

model CampaignRecipient {
  id         String    @id @default(cuid())
  campaignId String
  customerId String
  email      String
  status     String    @default("pending") // pending|sent|failed|bounced|unsubscribed
  sentAt     DateTime?
  openedAt   DateTime?
  clickedAt  DateTime?
  bouncedAt  DateTime?

  campaign   Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customer   Customer  @relation(fields: [customerId], references: [id])

  @@unique([campaignId, customerId])
  @@index([campaignId, status])
}

model CampaignProduct {
  id             String   @id @default(cuid())
  userId         String
  productName    String
  productImage   String?
  price          Float?
  compareAtPrice Float?
  description    String?
  category       String?
  productUrl     String?
  platformId     String?
  source         String   @default("manual")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
}

model EmailEvent {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  type            String    // sent | delivered | opened | clicked | bounced | complained | failed | unsubscribed
  email           String?
  resendMessageId String?
  metadata        String    @default("{}")
  openedAt        DateTime?
  clickedAt       DateTime?
  bouncedAt       DateTime?
  failedReason    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([campaignId, type])
  @@index([customerId])
  @@index([resendMessageId])
}

model CampaignOpen {
  id         String    @id @default(cuid())
  userId     String
  campaignId String
  campaign   Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  channel    String    @default("email")
  openedAt   DateTime  @default(now())

  @@index([userId, openedAt])
  @@index([campaignId])
  @@index([customerId])
}

model Customer {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  firstName   String?
  lastName    String?
  email       String
  phone       String?
  segment     String    @default("new")
  totalOrders Int       @default(0)
  totalSpent  Float     @default(0)
  avgOrder    Float     @default(0)
  lastOrder   DateTime?
  tags        String    @default("[]")
  score       Int       @default(50)

  platformId  String?   // Shopify customer ID, WooCommerce ID vb.
  source      String    @default("manual") // "shopify" | "woocommerce" | "trendyol" | "manual" | "csv"
  riskScore   String    @default("low")   // low | medium | high

  birthdayMonth Int?
  birthdayDay   Int?

  unsubscribed     Boolean   @default(false)
  unsubscribeToken String    @default(cuid())
  bounced          Boolean   @default(false)
  bouncedAt        DateTime?
  complained       Boolean   @default(false)
  complainedAt     DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  orders      Order[]
  events      CustomerEvent[]
  opens       CampaignOpen[]
  emailEvents EmailEvent[]
  campaignRecipients CampaignRecipient[]

  @@unique([userId, email])
}

// ─── Entegrasyon bağlantıları ──────────────────────────────────────────────

model Integration {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  platform    String   // "shopify" | "woocommerce" | "trendyol" | "hepsiburada"
  shopDomain  String?  // "mystore.myshopify.com"
  accessToken String?  // Shopify access token / WooCommerce key
  apiSecret   String?  // WooCommerce secret / Trendyol secret
  sellerId    String?  // Trendyol sellerId
  status      String   @default("active") // "active" | "error" | "disconnected"
  lastSyncAt  DateTime?
  webhookId   String?  // Shopify webhook ID (silmek için)
  meta        String   @default("{}") // JSON ek bilgi

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders          Order[]
  visitorSessions VisitorSession[]

  @@unique([userId, platform])
}

// ─── Sipariş verileri ──────────────────────────────────────────────────────

model Order {
  id              String      @id @default(cuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  integrationId   String?
  integration     Integration? @relation(fields: [integrationId], references: [id])
  customerId      String
  customer        Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)

  platformOrderId String?     // Shopify order ID
  orderNumber     String?     // Shopify #1001 gibi
  status          String      @default("pending") // pending|confirmed|shipped|delivered|cancelled|refunded
  financialStatus String?     // paid|pending|refunded vb.

  total           Float
  subtotal        Float       @default(0)
  shipping        Float       @default(0)
  discount        Float       @default(0)
  currency        String      @default("TRY")

  shippingCity    String?
  shippingCountry String?

  items           OrderItem[]
  events          CustomerEvent[]
  revenues        CampaignRevenue[]

  placedAt        DateTime    @default(now())
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([userId, platformOrderId])
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  platformId  String?
  title       String
  variantTitle String?
  quantity    Int
  price       Float
  imageUrl    String?
  productUrl  String?
}

// ─── Müşteri event'leri (otomasyon için tetikleyici) ──────────────────────

model CustomerEvent {
  id          String   @id @default(cuid())
  userId      String
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  orderId     String?
  order       Order?   @relation(fields: [orderId], references: [id])

  type        String   // cart_abandoned | order_placed | order_delivered | customer_created
                       // no_purchase_30d | no_purchase_60d | birthday | page_view
  data        String   @default("{}") // JSON: sipariş detayı, ürün bilgisi vb.
  source      String   @default("shopify") // hangi platform'dan geldi

  processedAt DateTime? // otomasyon engine bu event'i işledi mi
  createdAt   DateTime @default(now())

  @@index([userId, type, processedAt])
  @@index([customerId, type])
}

// ─── Diğer modeller ───────────────────────────────────────────────────────

model Automation {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  trigger     String   // cart_abandoned | order_placed | customer_created | no_purchase | birthday
  status      String   @default("draft") // draft | active | paused
  steps       String   @default("[]")    // JSON: [{channel, immediate, delayAmount, delayUnit, message}]
  segment     String?
  triggerConfig String @default("{}") // JSON: tetikleyici için özel ayarlar

  flowData    String   @default("{}")   // JSON: { nodes, edges }

  sent        Int      @default(0)
  opened      Int      @default(0)
  converted   Int      @default(0)
  revenue     Float    @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  runs        AutomationRun[]
}

// ─── Automation Runtime ───────────────────────────────────────────────────────

model AutomationRun {
  id            String    @id @default(cuid())
  automationId  String
  automation    Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)
  userId        String
  customerId    String

  status        String    @default("running") // running | waiting | completed | failed | stopped
  currentNodeId String?
  context       String    @default("{}") // JSON: { triggerData, vars }
  resumeAt      DateTime?
  completedAt   DateTime?
  failedAt      DateTime?
  failReason    String?
  meta          Json?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  steps         AutomationRunStep[]
  logs          AutomationLog[]

  @@index([automationId, status])
  @@index([userId, status])
  @@index([customerId])
  @@index([resumeAt])
}

model AutomationRunStep {
  id        String        @id @default(cuid())
  runId     String
  run       AutomationRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  nodeId    String
  nodeType  String
  nodeLabel String?
  status    String        @default("pending") // pending | running | completed | failed | skipped | waiting
  input     String        @default("{}")
  output    String        @default("{}")
  error     String?
  startedAt DateTime?
  endedAt   DateTime?

  createdAt DateTime       @default(now())

  @@index([runId])
}

model AutomationLog {
  id           String        @id @default(cuid())
  runId        String
  run          AutomationRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  automationId String
  userId       String
  customerId   String

  level        String        // info | warn | error
  message      String
  data         String        @default("{}")

  createdAt    DateTime      @default(now())

  @@index([runId])
  @@index([automationId, createdAt])
  @@index([userId, createdAt])
}

model Segment {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  description String?
  type        String   @default("custom")
  rules       String   @default("[]")
  matchType   String   @default("all")
  count       Int      @default(0)
  color       String   @default("violet")
  icon        String   @default("Users")
  active      Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Template {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  type        String
  category    String   @default("general")
  subject     String?
  body        String
  design      String   @default("[]")  // JSON: Block[] — editörde yeniden açmak için
  cta         String?
  isPublic    Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Sync logs ───────────────────────────────────────────────────────────────

model SyncLog {
  id            String   @id @default(cuid())
  userId        String
  platform      String   // "shopify" | "woocommerce" | "ikas"
  status        String   // "running" | "success" | "error"
  customers     Int      @default(0)
  orders        Int      @default(0)
  products      Int      @default(0)
  errorMessage  String?
  startedAt     DateTime @default(now())
  completedAt   DateTime?

  @@index([userId, platform, startedAt])
}

model EmailVerification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
}

model EmailDomain {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  domain      String
  resendId    String?
  status      String   @default("pending") // pending | verified | failed
  dnsRecords  String   @default("[]")      // JSON array of DNS records
  fromEmail   String?
  fromPrefix  String   @default("kampanya") // e.g. "info", "hello", "kampanya"
  senderName  String?                       // overrides User.storeName in From header

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, domain])
}

// ─── WhatsApp AI ──────────────────────────────────────────────────────────────

model WhatsAppSettings {
  id                   String   @id @default(cuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  botName              String   @default("Marksio Asistan")
  welcomeMessage       String   @default("Merhaba! Size nasıl yardımcı olabilirim?")
  fallbackMessage      String   @default("Üzgünüm, bu konuda yardımcı olamıyorum. Ekibimiz en kısa sürede iletişime geçecek.")
  tone                 String   @default("friendly")
  responseLength       String   @default("medium")
  emojiUsage           String   @default("low")
  humanHandoffMessage  String   @default("Sizi mağaza ekibimizle bağlıyorum.")
  businessHoursMessage String   @default("Mesai saatlerimiz dışında yazıyorsunuz. En kısa sürede yanıt vereceğiz.")
  language             String   @default("tr")

  autoResponseEnabled  Boolean  @default(true)
  businessHoursEnabled Boolean  @default(false)
  businessHoursStart   String   @default("09:00")
  businessHoursEnd     String   @default("18:00")

  metaAccessToken      String?
  phoneNumberId        String?
  businessAccountId    String?
  webhookVerifyToken   String?
  appSecret            String?
  connectionStatus     String   @default("disconnected")

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model WhatsAppQuickReply {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title           String
  triggerKeywords String
  responseText    String
  isActive        Boolean  @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

model WhatsAppConversation {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  customerPhone String
  customerName  String?
  status        String   @default("open")
  resolvedBy    String?
  lastMessage   String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  messages      WhatsAppMessage[]

  @@index([userId, status])
}

model WhatsAppMessage {
  id             String               @id @default(cuid())
  conversationId String
  conversation   WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  role           String
  content        String
  externalId     String?  // Meta message ID (for status tracking)
  status         String?  // sent | delivered | read | failed
  deliveredAt    DateTime?
  readAt         DateTime?
  failedAt       DateTime?
  createdAt      DateTime @default(now())

  @@index([conversationId])
  @@index([externalId])
}

// ─── Canlı Takip ─────────────────────────────────────────────────────────────

model VisitorSession {
  id          String      @id @default(cuid())
  storeId     String
  store       Integration @relation(fields: [storeId], references: [id], onDelete: Cascade)
  sessionId   String
  ip          String?
  city        String?
  country     String?
  device      String?
  browser     String?
  currentPage String?
  status      String      @default("active") // active | idle | left
  startedAt   DateTime    @default(now())
  lastSeenAt  DateTime    @default(now())

  events      VisitorEvent[]

  @@unique([storeId, sessionId])
  @@index([storeId, lastSeenAt])
}

model VisitorEvent {
  id        String         @id @default(cuid())
  sessionId String
  session   VisitorSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  storeId   String
  eventType String         // page_view | product_view | add_to_cart | checkout_start | heartbeat | page_leave
  pageUrl   String?
  metadata  Json?
  createdAt DateTime       @default(now())

  @@index([storeId, createdAt])
  @@index([sessionId])
}

// ─── WhatsApp Campaigns ───────────────────────────────────────────────────────

model WhatsAppCampaign {
  id                  String    @id @default(cuid())
  userId              String
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  name                String
  audienceSegmentId   String?
  message             String
  status              String    @default("draft")
  scheduledAt         DateTime?
  sentCount           Int       @default(0)
  failedCount         Int       @default(0)
  delivered           Int       @default(0)
  opened              Int       @default(0) // read receipts
  externalMessageId   String?   // last Meta message ID for status tracking

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([userId])
  @@index([externalMessageId])
}

// ─── E-posta Yönetim Merkezi ──────────────────────────────────────────────────

model EmailTemplate {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  type        String   @default("custom") // welcome|promotion|cart_abandonment|order_confirmation|win_back|custom
  subject     String?
  htmlContent String?
  textContent String?
  thumbnail   String?
  isDefault   Boolean  @default(false)
  usageCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
}

model EmailHealthScore {
  id              String   @id @default(cuid())
  userId          String   @unique
  score           Int      @default(100)
  bounceRate      Float    @default(0)
  complaintRate   Float    @default(0)
  openRate        Float    @default(0)
  deliveryRate    Float    @default(0)
  unsubscribeRate Float    @default(0)
  lastCalculated  DateTime @default(now())
  status          String   @default("good") // good|warning|danger

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ABTest {
  id            String    @id @default(cuid())
  userId        String
  name          String
  campaignId    String?
  variantA      Json
  variantB      Json
  splitPercent  Int       @default(50)
  status        String    @default("draft") // draft|running|completed
  winnerVariant String?
  sentA         Int       @default(0)
  sentB         Int       @default(0)
  openedA       Int       @default(0)
  openedB       Int       @default(0)
  clickedA      Int       @default(0)
  clickedB      Int       @default(0)
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

// ─── WhatsApp Business API (BYO Credentials) ─────────────────────────────────

enum QualityRating {
  GREEN
  YELLOW
  RED
  UNKNOWN
}

enum MessagingTier {
  TIER_250
  TIER_1K
  TIER_10K
  TIER_100K
  UNLIMITED
}

enum WhatsappAccountStatus {
  PENDING
  CONNECTED
  ERROR
  DISCONNECTED
}

enum TemplateCategory {
  MARKETING
  UTILITY
  AUTHENTICATION
}

enum WaTemplateStatus {
  PENDING
  APPROVED
  REJECTED
  PAUSED
  DISABLED
}

enum OptInStatus {
  OPTED_IN
  OPTED_OUT
  UNKNOWN
}

enum WaConversationStatus {
  AI_HANDLING
  HUMAN_TAKEOVER
  CLOSED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum WaMessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
}

enum BroadcastStatus {
  DRAFT
  SCHEDULED
  SENDING
  COMPLETED
  FAILED
}

model WhatsappAccount {
  id                 String               @id @default(cuid())
  userId             String
  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  wabaId             String
  phoneNumberId      String               @unique
  accessToken        String
  appSecret          String
  displayName        String?
  verifiedName       String?
  qualityRating      QualityRating        @default(UNKNOWN)
  messagingTier      MessagingTier        @default(TIER_250)
  webhookVerifyToken String               @unique
  status             WhatsappAccountStatus @default(PENDING)
  isDemo             Boolean              @default(false)
  lastWebhookAt      DateTime?
  lastSyncAt         DateTime?
  lastSyncError      String?
  connectedAt        DateTime             @default(now())
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  templates          WhatsappTemplate[]
  waConversations    WhatsappConversation[]
  broadcasts         WhatsappBroadcast[]
  assistantConfig    WhatsappAssistantConfig?
}

model WhatsappTemplate {
  id              String           @id @default(cuid())
  accountId       String
  account         WhatsappAccount  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  metaTemplateId  String
  name            String
  category        TemplateCategory
  language        String
  status          WaTemplateStatus
  componentsJson  Json
  rejectedReason  String?
  qualityRating   String?          // GREEN | YELLOW | RED (Meta quality score per template)
  submittedAt     DateTime?        // when first submitted to Meta (for pending age tracking)
  syncedAt        DateTime         @default(now())

  broadcasts      WhatsappBroadcast[]
  waMessages      WhatsappMessage[]
  versions        WhatsappTemplateVersion[]

  @@unique([accountId, metaTemplateId])
}

model WhatsappTemplateVersion {
  id             String           @id @default(cuid())
  templateId     String
  template       WhatsappTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  componentsJson Json
  status         String
  rejectedReason String?
  attemptNote    String?
  createdAt      DateTime         @default(now())

  @@index([templateId])
}

model WhatsappContact {
  id              String          @id @default(cuid())
  userId          String
  phoneNumber     String
  optInStatus     OptInStatus     @default(UNKNOWN)
  lastInboundAt   DateTime?
  windowExpiresAt DateTime?
  tags            String[]
  createdAt       DateTime        @default(now())

  conversations   WhatsappConversation[]

  @@unique([userId, phoneNumber])
}

model WhatsappConversation {
  id            String              @id @default(cuid())
  contactId     String
  contact       WhatsappContact     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  accountId     String
  account       WhatsappAccount     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  status        WaConversationStatus @default(AI_HANDLING)
  lastMessageAt DateTime            @default(now())
  demo          Boolean             @default(false)

  messages       WhatsappMessage[]
  aiDecisionLogs AiDecisionLog[]
  internalNotes  InternalNote[]
  tagLinks       ConversationTagLink[]
}

model AiDecisionLog {
  id              String               @id @default(cuid())
  conversationId  String
  conversation    WhatsappConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId          String

  intent          String?
  confidence      Float?
  knowledgeSource String?
  faqMatched      String?
  orderDataUsed   Boolean  @default(false)
  transferred     Boolean  @default(false)
  transferReason  String?
  action          String?
  responsePreview String?

  createdAt       DateTime @default(now())

  @@index([conversationId])
  @@index([userId, createdAt])
}

model InternalNote {
  id             String               @id @default(cuid())
  conversationId String
  conversation   WhatsappConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  note           String
  createdBy      String

  createdAt      DateTime @default(now())

  @@index([conversationId])
}

model ConversationTag {
  id        String   @id @default(cuid())
  userId    String
  name      String
  color     String   @default("#6B7280")
  createdAt DateTime @default(now())

  links     ConversationTagLink[]

  @@unique([userId, name])
  @@index([userId])
}

model ConversationTagLink {
  id             String               @id @default(cuid())
  conversationId String
  conversation   WhatsappConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  tagId          String
  tag            ConversationTag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt      DateTime             @default(now())

  @@unique([conversationId, tagId])
}

model WhatsappMessage {
  id             String              @id @default(cuid())
  conversationId String
  conversation   WhatsappConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  direction      MessageDirection
  templateId     String?
  template       WhatsappTemplate?   @relation(fields: [templateId], references: [id])
  content        String?
  metaMessageId  String?             @unique
  status         WaMessageStatus     @default(QUEUED)
  errorReason    String?
  sentAt         DateTime            @default(now())

  broadcast      WhatsappBroadcast?  @relation(fields: [broadcastId], references: [id])
  broadcastId    String?
}

model WhatsappBroadcast {
  id               String          @id @default(cuid())
  accountId        String
  account          WhatsappAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  templateId       String?
  template         WhatsappTemplate? @relation(fields: [templateId], references: [id])
  demo             Boolean @default(false)
  segmentId        String?
  name             String
  description      String?
  scheduledAt      DateTime?
  status           BroadcastStatus @default(DRAFT)
  sendType         String          @default("IMMEDIATE")
  totalRecipients  Int             @default(0)
  sentCount        Int             @default(0)
  deliveredCount   Int             @default(0)
  readCount        Int             @default(0)
  failedCount      Int             @default(0)
  clickCount       Int             @default(0)
  convertedCount   Int             @default(0)
  revenue          Float           @default(0)
  userId           String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  messages         WhatsappMessage[]
  conversions      WhatsappBroadcastConversion[]

  @@index([userId, createdAt])
  @@index([accountId, status])
}

model WhatsappBroadcastConversion {
  id          String            @id @default(cuid())
  broadcastId String
  broadcast   WhatsappBroadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  userId      String
  customerId  String?
  orderId     String?
  phoneNumber String
  revenue     Float             @default(0)
  createdAt   DateTime          @default(now())

  @@index([broadcastId])
  @@index([userId, createdAt])
}

enum AssistantTone {
  FORMAL
  FRIENDLY
  PROFESSIONAL
}

enum AssistantResponseLength {
  SHORT
  MEDIUM
  LONG
}

enum AssistantConfidenceLevel {
  LOW
  MEDIUM
  HIGH
}

enum HandoverRuleType {
  AI_CANNOT_RESOLVE
  ORDER_COMPLAINT
  RETURN_REQUEST
  ANGRY_CUSTOMER
  MANUAL_TRANSFER
}

enum KnowledgeSourceType {
  WEBSITE_URL
  PDF
  FAQ_IMPORT
  MANUAL
}

model WhatsappAssistantConfig {
  id                String                   @id @default(cuid())
  accountId         String                   @unique
  account           WhatsappAccount          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  enabled           Boolean                  @default(false)
  tone              AssistantTone            @default(PROFESSIONAL)
  responseLength    AssistantResponseLength  @default(MEDIUM)
  confidenceLevel   AssistantConfidenceLevel @default(MEDIUM)
  businessName      String?
  customKnowledge   String?
  fallbackMessage   String?
  websiteUrl        String?
  shopifyEnabled    Boolean                  @default(false)
  workingHoursStart String?
  workingHoursEnd   String?
  offlineMessage    String?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  faqs             WhatsappAssistantFaq[]
  handoverRules    WhatsappHandoverRule[]
  knowledgeSources WhatsappKnowledgeSource[]
}

model WhatsappAssistantFaq {
  id        String                  @id @default(cuid())
  configId  String
  config    WhatsappAssistantConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  question  String
  answer    String
  createdAt DateTime                @default(now())
}

model WhatsappHandoverRule {
  id       String                  @id @default(cuid())
  configId String
  config   WhatsappAssistantConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  ruleType HandoverRuleType
  enabled  Boolean                 @default(true)

  @@unique([configId, ruleType])
}

model WhatsappKnowledgeSource {
  id         String                  @id @default(cuid())
  configId   String
  config     WhatsappAssistantConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  sourceType KnowledgeSourceType
  title      String?
  content    String?
  url        String?
  fileName   String?
  storageUrl String?
  createdAt  DateTime                @default(now())
}

model WhatsappOptInHistory {
  id          String      @id @default(cuid())
  userId      String
  phoneNumber String
  status      OptInStatus
  source      String      @default("manual") // csv_import | webhook | manual | broadcast_unsubscribe
  note        String?
  createdAt   DateTime    @default(now())

  @@index([userId, phoneNumber])
  @@index([userId, createdAt])
}
