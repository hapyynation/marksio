generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String
  name        String
  storeName   String
  plan        String   @default("starter")
  currency    String   @default("TRY")
  language    String   @default("tr")
  timezone    String   @default("Europe/Istanbul")
  onboarded     Boolean  @default(false)
  onboardingData String  @default("{}")
  emailVerified Boolean  @default(false)

  // Lemon Squeezy billing
  lsSubscriptionId String?
  lsCustomerId      String?
  lsOrderId         String?
  planStatus        String   @default("active") // active | cancelled | expired | past_due
  planRenewsAt      DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaigns    Campaign[]
  emailVerifications EmailVerification[]
  customers    Customer[]
  automations  Automation[]
  segments     Segment[]
  templates    Template[]
  integrations Integration[]
  orders       Order[]
  emailDomains EmailDomain[]

  whatsappSettings     WhatsAppSettings?
  whatsappQuickReplies WhatsAppQuickReply[]
  whatsappConversations WhatsAppConversation[]
  whatsappCampaigns    WhatsAppCampaign[]
}

model Campaign {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  type        String
  status      String   @default("draft")
  segment     String
  subject     String?
  previewText String?
  headline    String?
  body        String
  design      String   @default("[]")
  cta         String?
  tips        String   @default("[]")
  purpose     String?
  imageUrl    String?
  imagePrompt String?
  htmlContent String?
  ctaText     String?
  layoutStyle String?
  brandColor  String?
  sentAt      DateTime?

  sent        Int      @default(0)
  opened      Int      @default(0)
  clicked     Int      @default(0)
  converted   Int      @default(0)
  revenue     Float    @default(0)

  productsJson  String   @default("[]")

  scheduledAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  opens       CampaignOpen[]
  emailEvents EmailEvent[]
  revenues    CampaignRevenue[]
}

// ─── Revenue Attribution ──────────────────────────────────────────────────────

model CampaignRevenue {
  id              String   @id @default(cuid())
  userId          String
  campaignId      String
  campaign        Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  orderId         String
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customerId      String

  revenue         Float    // attributed revenue
  orderTotal      Float    // original order total (before attribution split)
  attributionType String   @default("last_click") // last_click | first_click | assisted
  daysSinceClick  Int?
  touchCount      Int      @default(1) // # of campaigns that touched this customer

  createdAt       DateTime @default(now())

  @@unique([orderId, campaignId, attributionType])
  @@index([campaignId, createdAt])
  @@index([userId, createdAt])
  @@index([customerId])
}

model CampaignProduct {
  id             String   @id @default(cuid())
  userId         String
  productName    String
  productImage   String?
  price          Float?
  compareAtPrice Float?
  description    String?
  category       String?
  productUrl     String?
  platformId     String?
  source         String   @default("manual")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
}

model EmailEvent {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  type            String    // sent | delivered | opened | clicked | bounced | complained | failed | unsubscribed
  email           String?
  resendMessageId String?
  metadata        String    @default("{}")
  openedAt        DateTime?
  clickedAt       DateTime?
  bouncedAt       DateTime?
  failedReason    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([campaignId, type])
  @@index([customerId])
  @@index([resendMessageId])
}

model CampaignOpen {
  id         String    @id @default(cuid())
  userId     String
  campaignId String
  campaign   Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  channel    String    @default("email")
  openedAt   DateTime  @default(now())

  @@index([userId, openedAt])
  @@index([campaignId])
  @@index([customerId])
}

model Customer {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  firstName   String?
  lastName    String?
  email       String
  phone       String?
  segment     String    @default("new")
  totalOrders Int       @default(0)
  totalSpent  Float     @default(0)
  avgOrder    Float     @default(0)
  lastOrder   DateTime?
  tags        String    @default("[]")
  score       Int       @default(50)

  platformId  String?   // Shopify customer ID, WooCommerce ID vb.
  source      String    @default("manual") // "shopify" | "woocommerce" | "trendyol" | "manual" | "csv"

  unsubscribed     Boolean   @default(false)
  unsubscribeToken String    @default(cuid())
  bounced          Boolean   @default(false)
  bouncedAt        DateTime?
  complained       Boolean   @default(false)
  complainedAt     DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  orders      Order[]
  events      CustomerEvent[]
  opens       CampaignOpen[]
  emailEvents EmailEvent[]

  @@unique([userId, email])
}

// ─── Entegrasyon bağlantıları ──────────────────────────────────────────────

model Integration {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  platform    String   // "shopify" | "woocommerce" | "trendyol" | "hepsiburada"
  shopDomain  String?  // "mystore.myshopify.com"
  accessToken String?  // Shopify access token / WooCommerce key
  apiSecret   String?  // WooCommerce secret / Trendyol secret
  sellerId    String?  // Trendyol sellerId
  status      String   @default("active") // "active" | "error" | "disconnected"
  lastSyncAt  DateTime?
  webhookId   String?  // Shopify webhook ID (silmek için)
  meta        String   @default("{}") // JSON ek bilgi

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders      Order[]

  @@unique([userId, platform])
}

// ─── Sipariş verileri ──────────────────────────────────────────────────────

model Order {
  id              String      @id @default(cuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  integrationId   String?
  integration     Integration? @relation(fields: [integrationId], references: [id])
  customerId      String
  customer        Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)

  platformOrderId String?     // Shopify order ID
  orderNumber     String?     // Shopify #1001 gibi
  status          String      @default("pending") // pending|confirmed|shipped|delivered|cancelled|refunded
  financialStatus String?     // paid|pending|refunded vb.

  total           Float
  subtotal        Float       @default(0)
  shipping        Float       @default(0)
  discount        Float       @default(0)
  currency        String      @default("TRY")

  shippingCity    String?
  shippingCountry String?

  items           OrderItem[]
  events          CustomerEvent[]
  revenues        CampaignRevenue[]

  placedAt        DateTime    @default(now())
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([userId, platformOrderId])
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  platformId  String?
  title       String
  variantTitle String?
  quantity    Int
  price       Float
  imageUrl    String?
  productUrl  String?
}

// ─── Müşteri event'leri (otomasyon için tetikleyici) ──────────────────────

model CustomerEvent {
  id          String   @id @default(cuid())
  userId      String
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  orderId     String?
  order       Order?   @relation(fields: [orderId], references: [id])

  type        String   // cart_abandoned | order_placed | order_delivered | customer_created
                       // no_purchase_30d | no_purchase_60d | birthday | page_view
  data        String   @default("{}") // JSON: sipariş detayı, ürün bilgisi vb.
  source      String   @default("shopify") // hangi platform'dan geldi

  processedAt DateTime? // otomasyon engine bu event'i işledi mi
  createdAt   DateTime @default(now())

  @@index([userId, type, processedAt])
  @@index([customerId, type])
}

// ─── Diğer modeller ───────────────────────────────────────────────────────

model Automation {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  trigger     String   // cart_abandoned | order_placed | customer_created | no_purchase | birthday
  status      String   @default("draft") // draft | active | paused
  steps       String   @default("[]")    // JSON: [{channel, immediate, delayAmount, delayUnit, message}]
  segment     String?
  triggerConfig String @default("{}") // JSON: tetikleyici için özel ayarlar

  flowData    String   @default("{}")   // JSON: { nodes, edges }

  sent        Int      @default(0)
  opened      Int      @default(0)
  converted   Int      @default(0)
  revenue     Float    @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  runs        AutomationRun[]
}

// ─── Automation Runtime ───────────────────────────────────────────────────────

model AutomationRun {
  id            String    @id @default(cuid())
  automationId  String
  automation    Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)
  userId        String
  customerId    String

  status        String    @default("running") // running | waiting | completed | failed | stopped
  currentNodeId String?
  context       String    @default("{}") // JSON: { triggerData, vars }
  resumeAt      DateTime?
  completedAt   DateTime?
  failedAt      DateTime?
  failReason    String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  steps         AutomationRunStep[]
  logs          AutomationLog[]

  @@index([automationId, status])
  @@index([userId, status])
  @@index([customerId])
  @@index([resumeAt])
}

model AutomationRunStep {
  id        String        @id @default(cuid())
  runId     String
  run       AutomationRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  nodeId    String
  nodeType  String
  nodeLabel String?
  status    String        @default("pending") // pending | running | completed | failed | skipped | waiting
  input     String        @default("{}")
  output    String        @default("{}")
  error     String?
  startedAt DateTime?
  endedAt   DateTime?

  createdAt DateTime       @default(now())

  @@index([runId])
}

model AutomationLog {
  id           String        @id @default(cuid())
  runId        String
  run          AutomationRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  automationId String
  userId       String
  customerId   String

  level        String        // info | warn | error
  message      String
  data         String        @default("{}")

  createdAt    DateTime      @default(now())

  @@index([runId])
  @@index([automationId, createdAt])
  @@index([userId, createdAt])
}

model FlowExecution {
  id           String    @id @default(cuid())
  automationId String
  userId       String
  customerId   String
  nodeId       String    @default("")
  status       String    @default("pending")  // pending | running | waiting | completed | failed
  context      String    @default("{}")
  nextRunAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([automationId])
  @@index([userId, status])
  @@index([nextRunAt])
}

model Segment {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  description String?
  type        String   @default("custom")
  rules       String   @default("[]")
  matchType   String   @default("all")
  count       Int      @default(0)
  color       String   @default("violet")
  icon        String   @default("Users")
  active      Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Template {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  type        String
  category    String   @default("general")
  subject     String?
  body        String
  design      String   @default("[]")  // JSON: Block[] — editörde yeniden açmak için
  cta         String?
  isPublic    Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Sync logs ───────────────────────────────────────────────────────────────

model SyncLog {
  id            String   @id @default(cuid())
  userId        String
  platform      String   // "shopify" | "woocommerce" | "ikas"
  status        String   // "running" | "success" | "error"
  customers     Int      @default(0)
  orders        Int      @default(0)
  products      Int      @default(0)
  errorMessage  String?
  startedAt     DateTime @default(now())
  completedAt   DateTime?

  @@index([userId, platform, startedAt])
}

model EmailVerification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
}

model EmailDomain {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  domain      String
  resendId    String?
  status      String   @default("pending") // pending | verified | failed
  dnsRecords  String   @default("[]")      // JSON array of DNS records
  fromEmail   String?
  fromPrefix  String   @default("kampanya") // e.g. "info", "hello", "kampanya"
  senderName  String?                       // overrides User.storeName in From header

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, domain])
}

// ─── WhatsApp AI ──────────────────────────────────────────────────────────────

model WhatsAppSettings {
  id                   String   @id @default(cuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  botName              String   @default("Marksio Asistan")
  welcomeMessage       String   @default("Merhaba! Size nasıl yardımcı olabilirim?")
  fallbackMessage      String   @default("Üzgünüm, bu konuda yardımcı olamıyorum. Ekibimiz en kısa sürede iletişime geçecek.")
  tone                 String   @default("friendly")
  responseLength       String   @default("medium")
  emojiUsage           String   @default("low")
  humanHandoffMessage  String   @default("Sizi mağaza ekibimizle bağlıyorum.")
  businessHoursMessage String   @default("Mesai saatlerimiz dışında yazıyorsunuz. En kısa sürede yanıt vereceğiz.")
  language             String   @default("tr")

  autoResponseEnabled  Boolean  @default(true)
  businessHoursEnabled Boolean  @default(false)
  businessHoursStart   String   @default("09:00")
  businessHoursEnd     String   @default("18:00")

  metaAccessToken      String?
  phoneNumberId        String?
  businessAccountId    String?
  webhookVerifyToken   String?
  appSecret            String?
  connectionStatus     String   @default("disconnected")

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model WhatsAppQuickReply {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title           String
  triggerKeywords String
  responseText    String
  isActive        Boolean  @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

model WhatsAppConversation {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  customerPhone String
  customerName  String?
  status        String   @default("open")
  resolvedBy    String?
  lastMessage   String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  messages      WhatsAppMessage[]

  @@index([userId, status])
}

model WhatsAppMessage {
  id             String               @id @default(cuid())
  conversationId String
  conversation   WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  role           String
  content        String
  externalId     String?  // Meta message ID (for status tracking)
  status         String?  // sent | delivered | read | failed
  deliveredAt    DateTime?
  readAt         DateTime?
  failedAt       DateTime?
  createdAt      DateTime @default(now())

  @@index([conversationId])
  @@index([externalId])
}

model WhatsAppCampaign {
  id                  String    @id @default(cuid())
  userId              String
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  name                String
  audienceSegmentId   String?
  message             String
  status              String    @default("draft")
  scheduledAt         DateTime?
  sentCount           Int       @default(0)
  failedCount         Int       @default(0)
  delivered           Int       @default(0)
  opened              Int       @default(0) // read receipts
  externalMessageId   String?   // last Meta message ID for status tracking

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([userId])
  @@index([externalMessageId])
}
