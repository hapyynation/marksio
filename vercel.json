{
  "framework": "nextjs",
  "buildCommand": "prisma generate && prisma db push && next build",
  "crons": [
    { "path": "/api/cron/campaigns",    "schedule": "0 8 * * *"   },
    { "path": "/api/cron/automations",  "schedule": "0 9 * * *"   },
    { "path": "/api/cron/segments",     "schedule": "0 10 * * *"  },
    { "path": "/api/cron/shopify-sync", "schedule": "0 3 * * *"   }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options",           "value": "DENY" },
        { "key": "X-Content-Type-Options",    "value": "nosniff" },
        { "key": "Referrer-Policy",           "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",        "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ]
}
